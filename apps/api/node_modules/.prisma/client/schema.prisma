generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  STAFF
}

enum Priority {
  NORMAL
  URGENT
}

enum MeetingType {
  PHYSICAL
  VIRTUAL
}

enum AuditAction {
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  APPOINTMENT_DELETED
  STAFF_INVITED
  STAFF_UPDATED
  STAFF_DELETED
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_DELETED
  BRANCH_CREATED
  BRANCH_UPDATED
  BRANCH_DELETED
}

model Company {
  id        String     @id @default(uuid())
  name      String
  branches  Branch[]
  users     User[]
  hospitals Hospital[]
  auditLogs AuditLog[]
}

model Branch {
  id        String       @id @default(uuid())
  name      String
  address   String
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  users     UserBranch[]
  patients  Patient[]
  shifts    Shift[]
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String
  name                 String
  role                 Role            @default(STAFF)
  companyId            String
  company              Company         @relation(fields: [companyId], references: [id])
  branches             UserBranch[]
  canAccessAllBranches Boolean         @default(false)
  mustChangePassword   Boolean         @default(false)
  twoFactorSecret      String?
  twoFactorEnabled     Boolean         @default(false)
  auditLogs            AuditLog[]
  passwordResets       PasswordReset[]
}

model PasswordReset {
  id        String   @id @default(uuid())
  codeHash  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserBranch {
  userId   String
  branchId String
  user     User   @relation(fields: [userId], references: [id])
  branch   Branch @relation(fields: [branchId], references: [id])

  @@id([userId, branchId])
}

model Patient {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  gender      String
  dateOfBirth DateTime
  email       String?
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  shifts      Shift[]
}

model Hospital {
  id        String  @id @default(uuid())
  name      String
  address   String
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  shifts    Shift[]
}

model Shift {
  id         String      @id @default(uuid())
  startTime  DateTime
  endTime    DateTime
  notes      String?     @db.Text
  type       MeetingType @default(PHYSICAL)
  priority   Priority    @default(NORMAL)
  patientId  String
  patient    Patient     @relation(fields: [patientId], references: [id])
  branchId   String
  branch     Branch      @relation(fields: [branchId], references: [id])
  hospitalId String?
  hospital   Hospital?   @relation(fields: [hospitalId], references: [id])
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityId   String
  entityType String
  details    Json?
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  createdAt  DateTime    @default(now())

  @@index([companyId, createdAt])
  @@index([action])
  @@index([userId])
}
